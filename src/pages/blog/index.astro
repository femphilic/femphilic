---
import { getCollection } from "astro:content";
import Layout from "~/layouts/Layout.astro";

const posts = await getCollection("blog");
---

<Layout
  bodyClass="items-center"
  title="femphilic's blog"
  description="an index to all of my blog posts :>"
>
  <main class="max-w-prose flex w-full flex-col gap-4 p-4">
    <header class="flex flex-col gap-4">
      <header
        class="flex items-center divide-zinc-400 divide-x *:first:pr-2 *:not-first:px-2"
      >
        <a
          class="text-sm text-zinc-400 italic transition-colors hover:text-zinc-400/90"
          href="/">&lt;&lt; home</a
        >
      </header>
      <main class="flex flex-col">
        <h1 class="text-4xl font-bold">blog</h1>
        <p class="text-base text-zinc-300">
          an index to all of my blog posts :&gt;
        </p>
      </main>
    </header>
    <main class="flex flex-col gap-2">
      {
        posts
          .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
          .map((post) => (
            <a
              href={`/blog/${post.id}`}
              class="px-5 py-6 hover:bg-zinc-800/90 transition-colors rounded-2xl bg-zinc-800"
            >
              <time class="text-sm italic text-zinc-400 pb-2">
                {post.data.pubDate.toLocaleDateString("en")}
              </time>
              <h2 class="text-2xl font-bold">{post.data.title}</h2>
              <p class="text-base text-zinc-300">{post.data.description}</p>
            </a>
          ))
      }
    </main>
  </main>
</Layout>
